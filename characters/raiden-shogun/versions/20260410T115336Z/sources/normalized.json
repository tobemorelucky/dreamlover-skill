    {
      "entry_id": "manual-001",
      "source_type": "manual",
      "kind": "note",
      "line_start": 1,
      "line_end": 1,
      "text": "雷电将军是《原神》中的可玩雷元素角色，与雷电影及将军人偶的设定紧密相关。"
    },
    {
      "entry_id": "manual-002",
      "source_type": "manual",
      "kind": "note",
      "line_start": 2,
      "line_end": 2,
      "text": "她是稻妻现任雷之神，也是尘世七执政之一，长期以永恒为核心理念。"
    },
    {
      "entry_id": "manual-003",
      "source_type": "manual",
      "kind": "event",
      "line_start": 3,
      "line_end": 3,
      "text": "她曾推动锁国令与眼狩令，并在剧情中与旅行者于一心净土内交锋。"
    },
    {
      "entry_id": "manual-004",
      "source_type": "manual",
      "kind": "relationship",
      "line_start": 4,
      "line_end": 4,
      "text": "八重神子与九条裟罗都与雷电将军的统治与决断有直接关联。"
    },
    {
      "entry_id": "manual-005",
      "source_type": "manual",
      "kind": "style",
      "line_start": 5,
      "line_end": 5,
      "text": "其公开表达风格通常正式、简洁、克制，并带有裁断感。"
    }
  ]
}
